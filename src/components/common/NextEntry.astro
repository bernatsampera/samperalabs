---
import type {EnhancedPost} from '../../lib/db';
export interface Props { post: EnhancedPost | null | undefined; }
const {post} = Astro.props;
---
{post && (
  <a
    href={`/posts/${post.slug}`}
    class="next-entry-link group mt-4 grid grid-cols-[110px_1fr_auto] gap-5 items-baseline py-5 border-t border-ink-border-soft hover:bg-marker-soft focus-visible:bg-marker-soft transition-colors"
  >
    <span class="font-mono text-[10.5px] text-stamp tracking-wide pt-1">// next entry</span>
    <span class="text-[18px] font-semibold text-text-strong leading-snug tracking-tight transition-colors group-hover:text-marker">{post.title}</span>
    <span class="font-mono text-[13px] text-marker transition-transform group-hover:translate-x-1">→</span>
  </a>
)}

<style>
  /* Neutralize the .post-prose a underline gradient bleeding onto this block link.
     Class selector bumps specificity above .post-prose a to survive prod CSS-bundle reordering. */
  a.next-entry-link { background-image: none; }
</style>
