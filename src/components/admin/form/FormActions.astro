---
export interface Props {
  mode: 'create' | 'edit';
  cancelUrl: string;
  submitText?: string;
  cancelText?: string;
}

const {
  mode,
  cancelUrl,
  submitText = mode === 'create' ? 'Create Post' : 'Update Post',
  cancelText = 'Cancel'
} = Astro.props;
---

<div class="flex gap-4 pt-8">
  <button
    type="submit"
    class="px-6 py-3 bg-stamp text-ink rounded-sm hover:bg-stamp/90 transition-colors"
  >
    {submitText}
  </button>
  <a
    href={cancelUrl}
    class="px-6 py-3 border border-ink-border text-text-strong rounded-sm hover:bg-ink-3 transition-colors"
  >
    {cancelText}
  </a>
</div>
