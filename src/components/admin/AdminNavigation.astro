---
export interface Props {
  backUrl?: string;
  backText?: string;
}

const {backUrl, backText = 'Back'} = Astro.props;
---

<nav class="border-b border-ink-border">
  <div class="container mx-auto px-6 py-6 max-w-4xl">
    {
      backUrl && (
        <a href={backUrl} class="text-text-muted hover:text-text-strong transition-colors">
          ← {backText}
        </a>
      )
    }
  </div>
</nav>

