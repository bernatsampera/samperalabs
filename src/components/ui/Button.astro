---
export interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'ghost' | 'link' | 'outline';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  text?: string;
  id?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  target,
  type = 'button',
  disabled = false,
  class: className = '',
  text,
  id,
  ...rest
} = Astro.props;

const sizeClasses =
  size === 'xs'
    ? 'px-3 py-1 text-xs'
    : size === 'sm'
      ? 'px-4 py-2 text-sm'
      : size === 'lg'
        ? 'px-8 py-4 text-base'
        : 'px-6 py-3 text-sm';

const variantClasses =
  variant === 'outline' || variant === 'ghost' || variant === 'link'
    ? 'bg-transparent border border-ink-border text-text-strong hover:bg-ink-3'
    : variant === 'secondary'
      ? 'bg-ink-2 border border-ink-border text-text-strong hover:bg-ink-3'
      : 'bg-stamp text-ink hover:bg-stamp/90';

const classes = [
  'inline-flex items-center justify-center font-medium rounded-sm transition-colors',
  sizeClasses,
  variantClasses,
  className,
]
  .filter(Boolean)
  .join(' ');

const isLink = !!href;
const linkProps = target ? {target, rel: 'noopener noreferrer'} : {};
---

{
  isLink ? (
    <a href={href} class={classes} {...linkProps} {...rest} id={id} {...rest}>
      {text}
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled} id={id} {...rest}>
      {text}
    </button>
  )
}
