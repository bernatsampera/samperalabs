---
import PageLayout from '../layouts/PageLayout.astro';

const metadata = {
  title: 'About | Sampera Labs',
  description: 'About Bernat Sampera.',
};

const experience = [
  {
    visible: true,
    company: 'Ampeers Energy',
    position: 'Full Stack Software Developer',
    location: 'Munich, Germany',
    date: 'May 2022 – April 2025',
    summary: 'Developed a billing tenant application for buildings with renewable energy systems.',
    url: {label: '', href: ''},
  },
  {
    visible: true,
    company: 'Sport1',
    position: 'Frontend Developer',
    location: 'Munich, Germany',
    date: 'September 2020 – May 2022',
    summary: 'Developed and maintained frontend components and the overall website for sport1.de.',
    url: {label: 'sport1.de', href: 'https://sport1.de'},
  },
  {
    visible: true,
    company: 'Rücker Lypsa (Seat)',
    position: 'Software Developer',
    location: 'Barcelona, Spain',
    date: 'May 2019 – September 2020',
    summary: 'Implemented in-car web applications for Seat and Cupra models on tablet-based infotainment systems.',
    url: {label: '', href: ''},
  },
  {
    visible: true,
    company: 'Engineering & Project Management',
    position: 'Junior Web Developer',
    location: 'Barcelona, Spain',
    date: 'April 2018 – May 2019',
    summary: 'Development of the prototype of a Webapp based on ReactJS and Redux using the cloud based platform Autodesk Forge.',
    url: {label: '', href: ''},
  },
  {
    visible: true,
    company: 'Independent Contractor',
    position: 'Junior Web Developer',
    location: 'Remote',
    date: 'April 2018 – September 2018',
    summary: 'Provided freelance support for a hotel website, focusing on client and admin portal maintenance.',
    url: {label: '', href: ''},
  },
];
---

<PageLayout metadata={metadata}>
  <main class="mx-auto px-6 max-w-[680px]">
    <header class="pt-12 pb-2">
      <h1 class="font-display font-bold lowercase text-[64px] leading-[0.9] tracking-[-0.045em] text-text-strong">
        about<span class="text-marker">.</span>
      </h1>
    </header>

    <article class="post-prose mt-8">
      <p>
        Hi, I'm Bernat — an AI Engineer & Full Stack Developer exploring the current AI landscape and building awesome
        things with it.
      </p>
      <p>
        Sampera Labs specializes in integrating AI solutions into websites and applications. With expertise in both AI
        development and web technologies, we help businesses leverage cutting-edge artificial intelligence to create
        better user experiences.
      </p>
      <p>
        Our approach focuses on practical AI implementations that provide real value, from chatbots and recommendation
        systems to content generation and data analysis tools.
      </p>

      <h2 id="experience">Experience</h2>
      <ul>
        {
          experience
            .filter((exp) => exp.visible)
            .map((exp) => (
              <li>
                <strong>{exp.position}</strong> — {exp.company}, {exp.location}
                <br />
                <em>{exp.date}</em>
                <br />
                {exp.summary}
                {exp.url?.href && (
                  <>
                    {' '}
                    <a href={exp.url.href} target="_blank" rel="noopener noreferrer">
                      {exp.url.label || exp.company}
                    </a>
                  </>
                )}
              </li>
            ))
        }
      </ul>
    </article>
  </main>
</PageLayout>
